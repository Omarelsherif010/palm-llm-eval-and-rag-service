# LLM Provider — works with OpenAI, Anthropic (via proxy), or any OpenAI-compatible API
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.4-nano-2026-03-17

# RAG Service
RAG_DEFAULT_K=5
RAG_SIMILARITY_METRIC=cosine
RAG_DENYLIST_PATH=rag_service/denylist.txt
RAG_HIT_RATE_THRESHOLD=0.1
